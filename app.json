{
  "expo": {
    "name": "MyTwin",
    "slug": "my-twin",
    "scheme": "mytwin",
    "version": "16.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0014"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soulsync.mytwin",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "يحتاج التطبيق للميكروفون للمحادثات الصوتية.",
        "NSCameraUsageDescription": "للسماح لك بإرسال الصور إلى توأمك",
        "NSPhotoLibraryUsageDescription": "للسماح لك بمشاركة الصور مع توأمك",
        "NSLocationWhenInUseUsageDescription": "يستخدم الموقع لتحسين تجربة التوأم.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.soulsync.mytwin",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0014"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "VIBRATE",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "com.android.vending.BILLING"
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#7C3AED"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C3AED"
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "./plugins/withGooglePlayBilling",
      "./plugins/withAPIFix"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1b7f7005-4cab-4125-8649-5f5967d16ced"
      },
      "cli": {
        "appVersionSource": "local"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b5e2baa3-6015-40a5-9f31-115298d3b0c9"
    },
    "owner": "soulsync.x",
    "sdkVersion": "52.0.0",
    "jsEngine": "hermes"
  }
}
